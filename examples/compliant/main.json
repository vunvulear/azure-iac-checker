{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "parameters": {
    "location": {
      "type": "string",
      "defaultValue": "eastus2",
      "metadata": {
        "description": "Primary deployment region"
      }
    },
    "tenantId": {
      "type": "string",
      "metadata": {
        "description": "Azure AD tenant ID for Key Vault"
      }
    }
  },
  "variables": {
    "commonTags": {
      "app": "myapp",
      "env": "prod",
      "costCenter": "CC-1234",
      "owner": "team-platform",
      "createdBy": "ARM"
    }
  },
  "resources": [
    {
      "type": "Microsoft.Resources/resourceGroups",
      "apiVersion": "2022-09-01",
      "name": "rg-myapp-prod-eastus2-001",
      "location": "[parameters('location')]",
      "tags": "[variables('commonTags')]",
      "properties": {}
    },
    {
      "type": "Microsoft.Storage/storageAccounts",
      "apiVersion": "2023-01-01",
      "name": "stmyappprodeastus2001",
      "location": "[parameters('location')]",
      "tags": "[variables('commonTags')]",
      "sku": {
        "name": "Standard_GRS"
      },
      "kind": "StorageV2",
      "properties": {
        "minimumTlsVersion": "TLS1_2",
        "supportsHttpsTrafficOnly": true,
        "allowBlobPublicAccess": false,
        "networkAcls": {
          "defaultAction": "Deny",
          "bypass": "AzureServices"
        },
        "encryption": {
          "requireInfrastructureEncryption": true,
          "services": {
            "blob": { "enabled": true },
            "file": { "enabled": true }
          }
        }
      }
    },
    {
      "type": "Microsoft.KeyVault/vaults",
      "apiVersion": "2023-02-01",
      "name": "kv-myapp-prod-eus2-001",
      "location": "[parameters('location')]",
      "tags": "[variables('commonTags')]",
      "properties": {
        "tenantId": "[parameters('tenantId')]",
        "sku": {
          "family": "A",
          "name": "standard"
        },
        "enableRbacAuthorization": true,
        "enablePurgeProtection": true,
        "enableSoftDelete": true,
        "softDeleteRetentionInDays": 90,
        "networkAcls": {
          "defaultAction": "Deny",
          "bypass": "AzureServices"
        }
      }
    },
    {
      "type": "Microsoft.Network/virtualNetworks",
      "apiVersion": "2023-05-01",
      "name": "vnet-myapp-prod-eastus2-001",
      "location": "[parameters('location')]",
      "tags": "[variables('commonTags')]",
      "properties": {
        "addressSpace": {
          "addressPrefixes": ["10.0.0.0/16"]
        },
        "dhcpOptions": {
          "dnsServers": ["10.0.0.4", "10.0.0.5"]
        },
        "subnets": [
          {
            "name": "snet-app",
            "properties": {
              "addressPrefix": "10.0.1.0/24"
            }
          },
          {
            "name": "snet-data",
            "properties": {
              "addressPrefix": "10.0.2.0/24"
            }
          }
        ]
      }
    },
    {
      "type": "Microsoft.Insights/metricAlerts",
      "apiVersion": "2018-03-01",
      "name": "cpu-alert-high",
      "location": "global",
      "tags": "[variables('commonTags')]",
      "properties": {
        "severity": 2,
        "enabled": true,
        "description": "Alert when CPU exceeds 80%",
        "scopes": [],
        "evaluationFrequency": "PT5M",
        "windowSize": "PT15M",
        "criteria": {
          "odata.type": "Microsoft.Azure.Monitor.SingleResourceMultipleMetricCriteria",
          "allOf": [
            {
              "name": "HighCPU",
              "metricName": "Percentage CPU",
              "operator": "GreaterThan",
              "threshold": 80,
              "timeAggregation": "Average"
            }
          ]
        }
      }
    },
    {
      "type": "Microsoft.OperationalInsights/workspaces",
      "apiVersion": "2022-10-01",
      "name": "law-myapp-prod-eastus2-001",
      "location": "[parameters('location')]",
      "tags": "[variables('commonTags')]",
      "properties": {
        "sku": {
          "name": "PerGB2018"
        },
        "retentionInDays": 90
      }
    },
    {
      "type": "Microsoft.Insights/diagnosticSettings",
      "apiVersion": "2021-05-01",
      "name": "activity-log-export",
      "properties": {
        "workspaceId": "[resourceId('Microsoft.OperationalInsights/workspaces', 'law-myapp-prod-eastus2-001')]"
      }
    },
    {
      "type": "Microsoft.Consumption/budgets",
      "apiVersion": "2023-03-01",
      "name": "monthly-budget-prod",
      "properties": {
        "category": "Cost",
        "amount": 5000,
        "timeGrain": "Monthly",
        "timePeriod": {
          "startDate": "2025-01-01T00:00:00Z"
        }
      }
    }
  ],
  "outputs": {
    "storageAccountId": {
      "type": "string",
      "value": "[resourceId('Microsoft.Storage/storageAccounts', 'stmyappprodeastus2001')]"
    },
    "keyVaultUri": {
      "type": "string",
      "value": "[reference('kv-myapp-prod-eus2-001').vaultUri]"
    }
  }
}
